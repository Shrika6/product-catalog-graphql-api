APP_ENV=development
APP_PORT=8080
LOG_LEVEL=info
REQUEST_TIMEOUT_SECONDS=5

DB_HOST=localhost
DB_PORT=5432
DB_USER=catalog_user
DB_PASSWORD=catalog_password
DB_NAME=catalog_db
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MINUTES=30

# Optional Redis cache
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT auth (required for mutations)
JWT_SECRET=change-me
JWT_ISSUER=
JWT_AUDIENCE=

# Optional: enable basic auth for /query
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=
